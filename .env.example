# Agent Federation — Environment Configuration

# Server
PORT=18790
HOST=0.0.0.0

# OpenClaw Gateway
# Gateway OpenAI-uyumlu API sağlar. Token auth ile çalışır.
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_WORKSPACE=~/.openclaw/workspace

# Agent LLM Configuration
# OpenClaw Gateway kullanılıyorsa bu ayarlar otomatik yüklenir.
# Manuel override için aşağıdaki değerleri doldurun:
AGENT_LLM_BASE_URL=http://localhost:18789/v1
AGENT_LLM_API_KEY=
AGENT_LLM_MODEL=qwen3.5-plus

# Agent Identity
# IDENTITY.md ve SOUL.md OpenClaw workspace'den otomatik yüklenir.
# Manuel override:
AGENT_NAME=MrClaw
AGENT_SYSTEM_PROMPT=
