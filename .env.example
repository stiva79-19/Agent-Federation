# Agent Federation — Environment Configuration

# Server
PORT=18790
HOST=0.0.0.0

# OpenClaw Gateway
# Gateway OpenAI-uyumlu API sağlar. Token auth ile çalışır.
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_WORKSPACE=~/.openclaw/workspace

# Agent LLM Configuration
# OpenClaw Gateway kullanılıyorsa bu ayarlar otomatik yüklenir.
# Manuel override için aşağıdaki değerleri doldurun:
AGENT_LLM_BASE_URL=http://localhost:18789/v1
AGENT_LLM_API_KEY=
AGENT_LLM_MODEL=qwen3.5-plus

# Agent Identity
# IDENTITY.md ve SOUL.md OpenClaw workspace'den otomatik yüklenir.
# Manuel override:
AGENT_NAME=MrClaw
AGENT_SYSTEM_PROMPT=

# ─── Swarm Configuration ──────────────────────────────────────
# Swarm mode: Hyperswarm DHT uzerinden torrent-style P2P (varsayilan)
# Local mode: Dogrudan P2P baglanti (eski davranis)
# Hosted mode: Relay sunucusu uzerinden (DEPRECATED)
CONNECTION_MODE=swarm

# Maksimum peer sayisi (varsayilan: 7)
SWARM_MAX_PEERS=7

# Agent DID (opsiyonel — otomatik olusturulur)
AGENT_DID=did:claw:ali:mrclaw

# ─── Relay Configuration (DEPRECATED) ─────────────────────────
# Artik swarm mode onerilir. Relay mode geriye uyumluluk icin korunuyor.
RELAY_URL=wss://agent-federation-relay.onrender.com
# Veya kendi relay sunucunuz: RELAY_URL=wss://my-server.com

# ─── Relay Server Configuration (DEPRECATED) ──────────────────
# Bu ayarlar sadece relay-server.ts calistirildiginda gecerlidir.
RELAY_MODE=true
RELAY_PORT=8080
RELAY_MAX_ROOMS=100
RELAY_ROOM_TTL_HOURS=24
